# Convex deployment (generated by `bunx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Clerk authentication (from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook (create at https://dashboard.clerk.com → Webhooks → Add Endpoint)
# Endpoint URL: {your-deployed-url}/api/webhooks/clerk
# Events: user.created, user.updated
CLERK_WEBHOOK_SECRET=
